{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "lettr/lettr-wordpress",
    "description": "Lettr plugin for WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Lettr and contributors",
            "homepage": "https://lettr.com"
        }
    ],
    "scripts": {
        "lint": "phpcs",
        "format": "phpcbf",
        "build": [
            "rm -rf .build lettr.zip",
            "rsync -a --exclude='.git' --exclude='.git*' --exclude='.vscode' --exclude='.editorconfig' --exclude='vendor' --exclude='node_modules' --exclude='composer.json' --exclude='composer.lock' --exclude='phpcs.xml.dist' --exclude='renovate.json' --exclude='lettr.zip' --exclude='.build' --exclude='.DS_Store' ./ .build/lettr/",
            "( cd .build && zip -qr ../lettr.zip lettr )",
            "rm -rf .build",
            "echo Built lettr.zip"
        ]
    },
    "require": {
        "php": ">=7.2.24|^8"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
		"lock": false
    }
}
